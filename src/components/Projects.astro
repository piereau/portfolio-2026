---
import { Image } from 'astro:assets';

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');

const instantCityImages = Object.values(
	import.meta.glob<{ default: ImageMetadata }>('/src/assets/instant-city/*.png', { eager: true })
).map((m) => m.default);

const joCompanionImages = Object.values(
	import.meta.glob<{ default: ImageMetadata }>('/src/assets/jo-companion/*.{png,jpg}', { eager: true })
).map((m) => m.default);

const robotMowerImages = Object.values(
	import.meta.glob<{ default: ImageMetadata }>('/src/assets/robot-mower/*.png', { eager: true })
).map((m) => m.default);

const etaleImages = Object.values(
	import.meta.glob<{ default: ImageMetadata }>('/src/assets/etale-ta-connaissance/*.png', { eager: true })
).map((m) => m.default);

const projects = [
	{
		title: 'Instant City',
		description: 'Projet réalisé pour Christophe Mayet. Instant City est la première plateforme artistique, digitale et collaborative complètement dématérialisée et désintermédiée.',
		tags: ['UX/UI', 'Prototype Figma'],
		images: instantCityImages,
		bg: 'bg-green-950',
		bg_fill: '#052e16',
		wave_stroke: '#34d399',
		title_color: 'text-white',
		desc_color: 'text-emerald-300',
		tag_color: 'text-emerald-300 bg-emerald-900/50 border border-emerald-300',
		img_wrapper_class: 'drop-shadow-[0_8px_40px_rgba(0,0,0,0.35)]',
		img_class: '',
	},
	{
		title: 'Olympic Companion',
		description: 'Vivre les Jeux Olympiques, c’est vibrer à chaque instant — encore faut-il ne rien manquer. Ce prototype d\'application companion a été pensée pour offrir une expérience immersive et en temps réel, directement dans la poche des utilisateurs.',
		tags: ['UX/UI', 'Prototype Figma'],
		images: joCompanionImages,
		bg: 'bg-blue-950',
		bg_fill: '#172554',
		wave_stroke: '#22d3ee',
		title_color: 'text-white',
		desc_color: 'text-cyan-300',
		tag_color: 'text-cyan-300 bg-cyan-900/50 border border-cyan-300',
		img_wrapper_class: 'drop-shadow-[0_8px_40px_rgba(0,0,0,0.35)]',
		img_class: '',
	},
	{
		title: 'Herbobot',
		description: 'Désherber un vignoble ne devrait pas être une tâche répétitive. Ce robot tondeuse autonome explore et cartographie son environnement afin de tondre de manière intelligente et autonome. Conçu comme un projet d’ingénierie mêlant robotique, capteurs et algorithmes de navigation.',
		tags: ['Robotique', 'ROS2', 'Computer Vision', 'IoT', 'Embedded Systems'],
		images: robotMowerImages,
		video: 'herbobot-demo.mp4',
		bg: 'bg-sky-200',
		bg_fill: '#bae6fd',
		wave_stroke: '#0284c7',
		title_color: 'text-sky-950',
		desc_color: 'text-sky-800',
		tag_color: 'text-sky-300 bg-sky-900 border border-sky-300',
		img_wrapper_class: '',
		img_class: 'shadow-beautiful',
	},
	{
		title: 'Étale ta connaissance',
		description: ' Étale ta connaissance est une bibliothèque de savoir, réalisée pour une entreprise qui propose du tutorat à domicile, elle permet aux tuteurs de facilement ajouter n\’importe quelle type de ressources éducatives et de les partager en un clic avec quiconque ',
		tags: ['Firebase', 'EdTech'],
		images: etaleImages,
		bg: 'bg-violet-950',
		bg_fill: '#2e1065',
		wave_stroke: '#a78bfa',
		title_color: 'text-white',
		desc_color: 'text-violet-200',
		tag_color: 'text-violet-200 bg-violet-900/50 border border-violet-200',
		img_wrapper_class: 'drop-shadow-[0_8px_40px_rgba(0,0,0,0.35)]',
		img_class: '',
	},
	{
		title: 'Fidjoo',
		description:
			'Mini-jeux mobiles réalisés pour l\'application Fidjoo permettant à l\'utilisateur de se divertir pendant la génération de son histoire personnalisée.',
		tags: ['React Native', 'Mobile game'],
		images: [],
		videos: ['fidjoo-attrape.mp4', 'fidjoo-volant.mp4'],
		bg: 'bg-amber-50',
		bg_fill: '#fffbeb',
		wave_stroke: '#f59e0b',
		title_color: 'text-amber-950',
		desc_color: 'text-amber-800',
		tag_color: 'text-amber-900 bg-amber-200/80 border border-amber-400',
		img_wrapper_class: 'drop-shadow-[0_8px_40px_rgba(0,0,0,0.2)]',
		img_class: '',
	},
	{
		title: 'Dashboard Météo',
		description: 'Ce dashboard interactif permet d\'explorer une base de données de capteurs météorologiques (température, humidité, qualité de l\'air).',
		tags: ['react', 'MongoDB', 'IoT', 'data visualization'],
		images: [],
		video: 'sensor-dashboard-demo.mp4',
		bg: 'bg-zinc-100',
		bg_fill: '#f4f4f5',
		wave_stroke: '#71717a',
		title_color: 'text-zinc-900',
		desc_color: 'text-zinc-600',
		tag_color: 'text-zinc-800 bg-zinc-200 border border-zinc-400',
		img_wrapper_class: 'drop-shadow-[0_8px_40px_rgba(0,0,0,0.35)]',
		img_class: '',
	},
	{
		title: 'Habille-moi VR',
		description: 'Expérience VR amusante permettant de confectionner des tenues.',
		tags: ['VR', 'Unity', 'Meta Quest 3S'],
		images: [],
		video: 'habille-moi-vr-demo.mp4',
		bg: 'bg-fuchsia-50',
		bg_fill: '#fdf4ff',
		wave_stroke: '#c026d3',
		title_color: 'text-fuchsia-950',
		desc_color: 'text-fuchsia-800',
		tag_color: 'text-fuchsia-900 bg-fuchsia-200/80 border border-fuchsia-400',
		img_wrapper_class: 'drop-shadow-[0_8px_40px_rgba(0,0,0,0.15)]',
		img_class: '',
	},
];
---

{projects.map((project, idx) => (
	<section data-horizontal-section class={`horizontal-section relative ${project.bg}`}>
		<div class="absolute top-0 left-0 w-full -translate-y-full z-10">
			<svg class="block w-full" height="30" viewBox="0 0 1440 30" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
				<path d="M0 12 Q 18 2, 36 12 Q 54 22, 72 12 Q 90 2, 108 12 Q 126 22, 144 12 Q 162 2, 180 12 Q 198 22, 216 12 Q 234 2, 252 12 Q 270 22, 288 12 Q 306 2, 324 12 Q 342 22, 360 12 Q 378 2, 396 12 Q 414 22, 432 12 Q 450 2, 468 12 Q 486 22, 504 12 Q 522 2, 540 12 Q 558 22, 576 12 Q 594 2, 612 12 Q 630 22, 648 12 Q 666 2, 684 12 Q 702 22, 720 12 Q 738 2, 756 12 Q 774 22, 792 12 Q 810 2, 828 12 Q 846 22, 864 12 Q 882 2, 900 12 Q 918 22, 936 12 Q 954 2, 972 12 Q 990 22, 1008 12 Q 1026 2, 1044 12 Q 1062 22, 1080 12 Q 1098 2, 1116 12 Q 1134 22, 1152 12 Q 1170 2, 1188 12 Q 1206 22, 1224 12 Q 1242 2, 1260 12 Q 1278 22, 1296 12 Q 1314 2, 1332 12 Q 1350 22, 1368 12 Q 1386 2, 1404 12 Q 1422 22, 1440 12 L 1440 30 L 0 30 Z" fill={project.bg_fill}/>
				<path d="M0 6 Q 18 -4, 36 6 Q 54 16, 72 6 Q 90 -4, 108 6 Q 126 16, 144 6 Q 162 -4, 180 6 Q 198 16, 216 6 Q 234 -4, 252 6 Q 270 16, 288 6 Q 306 -4, 324 6 Q 342 16, 360 6 Q 378 -4, 396 6 Q 414 16, 432 6 Q 450 -4, 468 6 Q 486 16, 504 6 Q 522 -4, 540 6 Q 558 16, 576 6 Q 594 -4, 612 6 Q 630 16, 648 6 Q 666 -4, 684 6 Q 702 16, 720 6 Q 738 -4, 756 6 Q 774 16, 792 6 Q 810 -4, 828 6 Q 846 16, 864 6 Q 882 -4, 900 6 Q 918 16, 936 6 Q 954 -4, 972 6 Q 990 16, 1008 6 Q 1026 -4, 1044 6 Q 1062 16, 1080 6 Q 1098 -4, 1116 6 Q 1134 16, 1152 6 Q 1170 -4, 1188 6 Q 1206 16, 1224 6 Q 1242 -4, 1260 6 Q 1278 16, 1296 6 Q 1314 -4, 1332 6 Q 1350 16, 1368 6 Q 1386 -4, 1404 6 Q 1422 16, 1440 6" stroke={idx === 0 ? '#d4d4d4' : projects[idx - 1].wave_stroke} stroke-width="1" fill="none"/>
			</svg>
		</div>
		<div class="pin-wrap-sticky">
			<div class="pin-wrap flex items-center">
				<div class="shrink-0 w-screen h-screen flex items-center justify-start px-6 md:px-[10vw] lg:px-[20vw]">
					<div class="max-w-lg">
						<h2 class={`font-[Space_Grotesk] text-4xl md:text-5xl lg:text-7xl font-bold tracking-tight md:whitespace-nowrap ${project.title_color}`}>
							{project.title}
						</h2>
						<p class={`mt-4 font-[Space_Grotesk] text-lg leading-relaxed ${project.desc_color}`}>
							{project.description}
						</p>
						<div class="flex flex-wrap gap-2 mt-6">
							{project.tags.map((tag) => (
								<span class={`px-3 py-1 text-xs font-mono uppercase tracking-wider rounded-[6px] ${project.tag_color}`}>
									{tag}
								</span>
							))}
						</div>
					</div>
				</div>
				{project.images.map((img, i) => (
					<div class={`shrink-0 h-screen flex items-center justify-center mx-8 md:mx-16 ${project.img_wrapper_class}`}>
						<Image
							src={img}
							alt={`${project.title} screenshot ${i + 1}`}
							widths={[900, 1400, 1920]}
							sizes="(max-width: 768px) 80vw, 60vw"
							decoding="async"
							loading={i < 2 ? 'eager' : 'lazy'}
							class={`h-[85vh] w-auto max-w-[80vw] object-contain rounded-2xl ${project.img_class}`}
						/>
					</div>
				))}
				{(project.videos ?? (project.video ? [project.video] : [])).map((src, vi) => (
					<div class={`shrink-0 h-screen flex items-center justify-center mx-8 md:mx-16 drop-shadow-[0_8px_40px_rgba(0,0,0,0.35)]`}>
						<video
							src={`${base}${src}`}
							autoplay
							muted
							loop
							playsinline
							class="h-[85vh] w-auto max-w-[80vw] rounded-2xl"
						/>
					</div>
				))}
			</div>
		</div>
	</section>
))}

<style>
	.shadow-beautiful {
		box-shadow:
			-7px 30px 67px 0px rgba(0, 0, 0, 0.14),
			-29px 119px 123px 0px rgba(0, 0, 0, 0.12),
			-64px 268px 165px 0px rgba(0, 0, 0, 0.07),
			-114px 477px 196px 0px rgba(0, 0, 0, 0.02),
			-178px 745px 214px 0px rgba(0, 0, 0, 0.00);
	}

	.horizontal-section {
		height: 700vh;
		overflow: visible;
	}

	.pin-wrap-sticky {
		height: 100vh;
		width: 100vw;
		position: sticky;
		top: 0;
		overflow-x: hidden;
	}

	.pin-wrap {
		height: 100vh;
		width: max-content;
		will-change: transform;
	}
</style>

<script>
	document.querySelectorAll('[data-horizontal-section]').forEach((section) => {
		const pinWrap = section.querySelector('.pin-wrap');
		if (!pinWrap || !('ViewTimeline' in window)) return;

		pinWrap.animate(
			{
				transform: ['translateX(0)', 'translateX(calc(-100% + 100vw))'],
			},
			{
				timeline: new ViewTimeline({
					subject: section,
					axis: 'block',
				}),
				fill: 'forwards',
				rangeStart: 'contain 0%',
				rangeEnd: 'contain 100%',
			}
		);
	});
</script>
